    {
      "name": "query-over-mcp",
      "whenToUse": "When an MCP host needs read-only tools for latest, search, and exact build retrieval.",
      "discovery": "https://yohei.me/.well-known/mcp"
    }
  ],
  "authentication": "none",
  "cost": "free",
  "dataPolicy": "Only records explicitly tagged public are exposed."
